# Unidad de servicio systemd para el demonio de radioenlace eQSO ASORAPA.
#
# Es una plantilla (@): el nombre de instancia es la sala a la que se conecta.
# Ejemplos:
#   systemctl enable --now eqso-relay@CB
#   systemctl enable --now eqso-relay@ASORAPA
#   systemctl enable --now eqso-relay@PRUEBAS
#
# Para cada instancia debe existir el archivo de configuracion:
#   /etc/eqso-relay/<instancia>.json
#
# Instalacion:
#   sudo cp eqso-relay@.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now eqso-relay@CB

[Unit]
Description=eQSO Radioenlace — sala %i
Documentation=https://github.com/daycart/eqso-linux-client
After=network-online.target sound.target
Wants=network-online.target
StartLimitIntervalSec=120
StartLimitBurst=5

[Service]
Type=simple
User=eqso
Group=audio

# La instancia (%i) determina que archivo de config leer
Environment=RELAY_INSTANCE=%i
Environment=NODE_ENV=production

# Ruta al daemon compilado (ajustar si se instala en otro lugar)
WorkingDirectory=/opt/eqso-asorapa/artifacts/relay-daemon

# Pre-arranque: liberar el dispositivo USB audio antes de arrancar.
# Cuando un aplay anterior queda en D-state (sleep ininterrumpible en el
# driver snd_usb_audio), 'modprobe -r' falla ("Module is in use").
# La solucion es resetear el dispositivo USB via sysfs/authorized:
#   echo 0 > .../authorized  → el kernel desconecta el USB, el D-state
#                               process recibe ENODEV y muere inmediatamente
#   sleep 1                  → esperar a que muera y que udev re-enumere
#   echo 1 > .../authorized  → reconecta el dispositivo USB al kernel
# Se ejecuta como root (prefijo '+') para poder escribir en /sys.
ExecStartPre=+/bin/sh -c '\
  pkill -KILL -x aplay 2>/dev/null; pkill -KILL -x arecord 2>/dev/null; sleep 0.3; \
  python3 -c "\
import fcntl, subprocess, re, time, sys; \
USBDEVFS_RESET = 21524; \
out = subprocess.check_output([\"lsusb\"]).decode(); \
found = False; \
[ (setattr(sys, \"_m\", re.search(r\"Bus (\d+) Device (\d+)\", l)) or True) and sys._m and re.search(r\"audio|CM108|C-Media\", l, re.I) and __import__(\"builtins\").__dict__.update({\"_p\": f\"/dev/bus/usb/{sys._m.group(1)}/{sys._m.group(2).zfill(3)}\"}) or True for l in out.splitlines()]; \
p = globals().get(\"_p\") or None; \
[ open(p, \"wb\") and True for p in ([p] if p else []) and [open(p,\"wb\")] if (lambda f: (fcntl.ioctl(f,USBDEVFS_RESET,0) or True) and f.close() or True)(open(p,\"wb\")) else [] ]; \
" 2>/dev/null || true; \
python3 -c "\
import fcntl, subprocess, re, time; \
USBDEVFS_RESET = 21524; \
out = subprocess.check_output([\"lsusb\"]).decode(); \
for line in out.splitlines(): \
    m = re.search(r\"Bus (\d+) Device (\d+)\", line); \
    if m and re.search(r\"audio|CM108|C-Media\", line, re.I): \
        path = \"/dev/bus/usb/{}/{}\".format(m.group(1), m.group(2).zfill(3)); \
        fd = open(path, \"wb\"); fcntl.ioctl(fd, USBDEVFS_RESET, 0); fd.close(); \
        print(\"USB reset: \" + path); time.sleep(1); \
" 2>&1 | head -5 || true; \
sleep 2'
ExecStart=/usr/bin/node --enable-source-maps dist/main.mjs

# Reinicio automatico: siempre, excepto si se para manualmente
Restart=always
RestartSec=5s

# Salida de log a journald (acceso via: journalctl -u eqso-relay@%i -f)
StandardOutput=journal
StandardError=journal
SyslogIdentifier=eqso-relay-%i

# Seguridad basica (solo lo estrictamente necesario)
PrivateTmp=true
ProtectSystem=full
NoNewPrivileges=true

# Permite acceso a /dev/snd para ALSA
SupplementaryGroups=audio

# Senales de parada:
# control-group — systemd mata TODOS los procesos del cgroup (node + aplay + arecord)
# cuando se detiene el servicio, sin esperar a que Node los mate el mismo.
# Necesario porque aplay puede quedar en D-state (sleep ininterrumpible ALSA USB)
# y no responder a SIGTERM; con control-group + SIGKILL el kernel lo limpia
# en cuanto el hardware libera el wait.
KillMode=control-group
KillSignal=SIGKILL
TimeoutStopSec=5

# Limpieza post-parada: reset USB via sysfs (mismo metodo que ExecStartPre).
ExecStopPost=+/bin/sh -c '\
  pkill -KILL -x aplay 2>/dev/null; pkill -KILL -x arecord 2>/dev/null; \
  for d in /sys/bus/usb/devices/*/; do \
    if grep -qiE "audio|CM108|C-Media" "${d}product" 2>/dev/null; then \
      echo 0 > "${d}authorized" 2>/dev/null && sleep 0.5 && echo 1 > "${d}authorized" 2>/dev/null; \
    fi; \
  done; \
  true'

[Install]
WantedBy=multi-user.target
